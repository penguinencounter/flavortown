<%# Renders a ledger entry log table.
    Usage:
      render "admin/shared/ledger_log", entries: @user.ledger_entries
      render "admin/shared/ledger_log", entries: LedgerEntry.where(...), title: "Project Ledger"
    Optional: title (default "Ledger History") %>
<% entries = local_assigns[:entries] || LedgerEntry.none %>
<% title = local_assigns.fetch(:title, "Ledger History") %>
<% entries = entries.order(created_at: :desc) %>
<% displayed_entries = entries.includes(:user) %>

<div class="card" style="margin-top: 1.5rem;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
    <h3 style="margin: 0;">🍪 <%= title %></h3>
    <span class="audit-logs__muted"><%= entries.count %> entries</span>
  </div>

  <% if displayed_entries.any? %>
    <table class="table-data">
      <thead>
        <tr>
          <th>Timestamp</th>
          <th>User</th>
          <th>Amount</th>
          <th>Reason</th>
          <th>Source</th>
          <th>Created By</th>
        </tr>
      </thead>
      <tbody>
        <% displayed_entries.each do |entry| %>
          <tr>
            <td class="audit-logs__timestamp">
              <span class="audit-logs__date"><%= entry.created_at.strftime("%b %d, %Y") %></span>
              <span class="audit-logs__time"><%= entry.created_at.strftime("%H:%M:%S") %></span>
            </td>
            <td>
              <% if entry.user %>
                <div class="audit-logs__user">
                  <img src="<%= entry.user.avatar %>" alt="" class="audit-logs__user-avatar">
                  <span><%= entry.user.display_name %></span>
                </div>
              <% else %>
                <span class="audit-logs__muted">—</span>
              <% end %>
            </td>
            <td>
              <span class="badge <%= entry.amount.positive? ? 'badge-create' : 'badge-destroy' %>">
                <%= entry.amount.positive? ? "+#{entry.amount}" : entry.amount %> 🍪
              </span>
            </td>
            <td><%= truncate(entry.reason.to_s, length: 60) %></td>
            <td>
              <code style="font-size: 0.75rem;"><%= entry.ledgerable_type.underscore.humanize %> #<%= entry.ledgerable_id %></code>
            </td>
            <td class="audit-logs__muted"><%= entry.created_by %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="audit-logs__muted" style="text-align: center; padding: 1rem; margin: 0;">No ledger entries yet.</p>
  <% end %>
</div>
